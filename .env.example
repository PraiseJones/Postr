# ── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────
# The public origin of this app (used to build OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── X (Twitter) — https://developer.x.com ────────────────────────────────
# OAuth 2.0 Client ID/Secret from your X app (User authentication settings).
# Redirect URI to register: {NEXT_PUBLIC_APP_URL}/api/connect/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Meta (Facebook + Instagram) — https://developers.facebook.com ────────
# One Meta app covers both platforms.
# Redirect URIs to register:
#   {NEXT_PUBLIC_APP_URL}/api/connect/facebook/callback
#   {NEXT_PUBLIC_APP_URL}/api/connect/instagram/callback
META_APP_ID=
META_APP_SECRET=

# ── LinkedIn — https://developer.linkedin.com ────────────────────────────
# Products required: "Sign In with LinkedIn using OpenID Connect" and
# "Share on LinkedIn".
# Redirect URI to register: {NEXT_PUBLIC_APP_URL}/api/connect/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Sentry (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
